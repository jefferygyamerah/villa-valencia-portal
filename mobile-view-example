<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>APROVIVA Operations</title>
<style>
:root{--bg:#0f1117;--surface:#1a1d27;--card:#22252f;--border:#2e3140;--primary:#6c5ce7;--primary-light:#a29bfe;--accent:#00cec9;--warn:#fdcb6e;--danger:#e17055;--success:#00b894;--text:#e8e8ee;--text2:#9ca3af;--text3:#6b7280;--radius:12px;--nav-h:60px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh}
button{cursor:pointer;font-family:inherit;border:none;background:none;color:var(--text)}
input,select,textarea{font-family:inherit;background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:8px;padding:8px 12px;width:100%;outline:none}
input:focus,select:focus,textarea:focus{border-color:var(--primary)}

/* Shell */
.app{display:flex;flex-direction:column;height:100vh;max-width:430px;margin:0 auto;position:relative;overflow:hidden}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--surface);border-bottom:1px solid var(--border);min-height:56px;z-index:10}
.topbar h1{font-size:16px;font-weight:700}
.topbar .sub{font-size:11px;color:var(--text2)}
.content{flex:1;overflow-y:auto;padding:16px;padding-bottom:calc(var(--nav-h) + 20px)}
.bottomnav{position:absolute;bottom:0;left:0;right:0;height:var(--nav-h);background:var(--surface);border-top:1px solid var(--border);display:flex;z-index:10}
.bottomnav button{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;font-size:10px;color:var(--text3);transition:.2s}
.bottomnav button.active{color:var(--primary-light)}
.bottomnav button .ico{font-size:20px}

/* Role Switcher */
.role-bar{display:flex;gap:6px;padding:10px 16px;background:var(--surface);overflow-x:auto;border-bottom:1px solid var(--border)}
.role-bar button{padding:6px 12px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap;background:var(--card);color:var(--text2);transition:.2s;border:1px solid transparent}
.role-bar button.active{background:var(--primary);color:#fff;border-color:var(--primary)}

/* Cards */
.card{background:var(--card);border-radius:var(--radius);padding:16px;margin-bottom:12px;border:1px solid var(--border)}
.card h3{font-size:14px;margin-bottom:6px}
.card p{font-size:13px;color:var(--text2);line-height:1.5}
.card-row{display:flex;gap:10px;margin-bottom:12px}
.card-row .card{flex:1;text-align:center}
.stat-val{font-size:24px;font-weight:700;margin:4px 0}
.stat-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px}

/* Badges */
.badge{display:inline-block;padding:3px 8px;border-radius:10px;font-size:11px;font-weight:600}
.badge-warn{background:rgba(253,203,110,.15);color:var(--warn)}
.badge-danger{background:rgba(225,112,85,.15);color:var(--danger)}
.badge-success{background:rgba(0,184,148,.15);color:var(--success)}
.badge-info{background:rgba(108,92,231,.15);color:var(--primary-light)}
.badge-accent{background:rgba(0,206,201,.15);color:var(--accent)}

/* Buttons */
.btn{padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;transition:.2s}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-light)}
.btn-sm{padding:6px 14px;font-size:12px}
.btn-outline{border:1px solid var(--border);color:var(--text2)}
.btn-outline:hover{border-color:var(--primary);color:var(--primary-light)}
.btn-danger{background:var(--danger);color:#fff}
.btn-success{background:var(--success);color:#fff}
.btn-block{display:block;width:100%;text-align:center}

/* Lists */
.list-item{display:flex;align-items:center;gap:12px;padding:12px;background:var(--card);border-radius:var(--radius);margin-bottom:8px;border:1px solid var(--border);cursor:pointer;transition:.15s}
.list-item:hover{border-color:var(--primary)}
.list-item .ico{font-size:24px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:var(--surface);border-radius:10px;flex-shrink:0}
.list-item .info{flex:1;min-width:0}
.list-item .info h4{font-size:13px;margin-bottom:2px}
.list-item .info p{font-size:11px;color:var(--text3)}
.list-item .trail{text-align:right;flex-shrink:0}

/* Pipeline */
.pipeline{display:flex;gap:4px;margin:12px 0;overflow-x:auto}
.pipe-stage{flex:1;min-width:0;text-align:center;padding:6px 4px;border-radius:6px;font-size:10px;font-weight:600;background:var(--surface);color:var(--text3);white-space:nowrap}
.pipe-stage.active{background:var(--primary);color:#fff}
.pipe-stage.done{background:var(--success);color:#fff}

/* Modal / Bottom Sheet */
.sheet-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;display:flex;align-items:flex-end;justify-content:center}
.sheet{background:var(--surface);border-radius:16px 16px 0 0;padding:20px 16px 30px;width:100%;max-width:430px;max-height:80vh;overflow-y:auto}
.sheet h2{font-size:16px;margin-bottom:16px}
.sheet .close-btn{position:absolute;top:12px;right:16px;font-size:20px;color:var(--text3)}
.field{margin-bottom:14px}
.field label{display:block;font-size:12px;color:var(--text2);margin-bottom:4px}

/* Offline Banner */
.offline-banner{background:var(--warn);color:#000;text-align:center;padding:6px;font-size:12px;font-weight:600}

/* Sequential Card */
.seq-card{background:var(--card);border-radius:var(--radius);padding:24px;text-align:center;border:1px solid var(--border)}
.seq-card .seq-title{font-size:18px;font-weight:700;margin-bottom:4px}
.seq-card .seq-sub{font-size:13px;color:var(--text2);margin-bottom:20px}
.seq-progress{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:16px}
.seq-progress .bar{flex:1;max-width:200px;height:6px;background:var(--surface);border-radius:3px;overflow:hidden}
.seq-progress .bar .fill{height:100%;background:var(--primary);border-radius:3px;transition:.3s}
.seq-progress span{font-size:12px;color:var(--text3)}
.qty-control{display:flex;align-items:center;justify-content:center;gap:16px;margin:16px 0}
.qty-control button{width:44px;height:44px;border-radius:50%;background:var(--surface);font-size:20px;font-weight:700;border:1px solid var(--border)}
.qty-control .qty{font-size:28px;font-weight:700;min-width:60px;text-align:center}

/* Tabs */
.tabs{display:flex;gap:4px;margin-bottom:16px;overflow-x:auto}
.tabs button{padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;white-space:nowrap;background:var(--card);color:var(--text2);border:1px solid var(--border)}
.tabs button.active{background:var(--primary);color:#fff;border-color:var(--primary)}

/* Gauge */
.gauge-wrap{text-align:center;margin:16px 0}
.gauge-circle{width:140px;height:140px;border-radius:50%;border:8px solid var(--surface);display:inline-flex;align-items:center;justify-content:center;flex-direction:column;position:relative}
.gauge-circle::before{content:'';position:absolute;inset:-8px;border-radius:50%;border:8px solid transparent;border-top-color:var(--primary);border-right-color:var(--primary);transform:rotate(45deg)}
.gauge-val{font-size:28px;font-weight:700}
.gauge-unit{font-size:11px;color:var(--text3)}

/* Timeline */
.timeline-item{display:flex;gap:12px;margin-bottom:16px;position:relative}
.timeline-item::before{content:'';position:absolute;left:15px;top:32px;bottom:-16px;width:2px;background:var(--border)}
.timeline-item:last-child::before{display:none}
.timeline-dot{width:32px;height:32px;border-radius:50%;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;border:2px solid var(--border);z-index:1}
.timeline-content{flex:1;background:var(--card);border-radius:8px;padding:10px 12px}
.timeline-content h4{font-size:12px;margin-bottom:2px}
.timeline-content p{font-size:11px;color:var(--text3)}
.timeline-content .time{font-size:10px;color:var(--text3);margin-top:4px}

.hidden{display:none!important}
.section-title{font-size:13px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin:16px 0 8px}
.mb-12{margin-bottom:12px}
.mt-8{margin-top:8px}
.flex-between{display:flex;align-items:center;justify-content:space-between}
.gap-8{gap:8px}
.text-center{text-align:center}
</style>
</head>
<body>

<div class="app" id="app"></div>

