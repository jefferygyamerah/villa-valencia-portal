// ===================== SEQUENTIAL MODES =====================
function renderSeqInvCount(){
  const item=S.invItems[S.seqIdx];
  const pct=Math.round((S.seqIdx/S.invItems.length)*100);
  return `
    <div class="flex-between mb-12"><button class="btn btn-sm btn-outline" onclick="exitSeq()">✕ Salir</button><span style="font-size:12px;color:var(--text2)">Conteo Completo</span></div>
    <div class="seq-card">
      <div class="seq-progress"><div class="bar"><div class="fill" style="width:${pct}%"></div></div><span>${S.seqIdx+1}/${S.invItems.length}</span></div>
      <div class="seq-title">${item.name}</div>
      <div class="seq-sub">${item.cat} · Mínimo: ${item.min} ${item.unit}</div>
      <div class="qty-control">
        <button onclick="adjQty(-1)">−</button>
        <div class="qty">${item.qty}</div>
        <button onclick="adjQty(1)">+</button>
      </div>
      <div style="font-size:12px;color:var(--text3);margin-bottom:16px">${item.unit}</div>
      <div style="display:flex;gap:8px">
        ${S.seqIdx>0?'<button class="btn btn-outline" style="flex:1" onclick="seqPrev()">← Anterior</button>':''}
        <button class="btn btn-primary" style="flex:1" onclick="seqNext()">${S.seqIdx===S.invItems.length-1?'✓ Finalizar':'Siguiente →'}</button>
      </div>
    </div>`;
}

function renderSeqWalkthrough(){
  const area=S.inspAreas[S.seqIdx];
  const pct=Math.round((S.seqIdx/S.inspAreas.length)*100);
  return `
    <div class="flex-between mb-12"><button class="btn btn-sm btn-outline" onclick="exitSeq()">✕ Salir</button><span style="font-size:12px;color:var(--text2)">Recorrido Áreas Comunes</span></div>
    <div class="seq-card">
      <div class="seq-progress"><div class="bar"><div class="fill" style="width:${pct}%"></div></div><span>${S.seqIdx+1}/${S.inspAreas.length}</span></div>
      <div class="seq-title">${area.name}</div>
      <div class="seq-sub">Última inspección: ${area.lastCheck}</div>
      <div style="width:100%;height:120px;background:var(--surface);border-radius:8px;display:flex;align-items:center;justify-content:center;margin:12px 0;font-size:32px">📷</div>
      <button class="btn btn-sm btn-outline mb-12">Tomar Foto</button>
      <div class="section-title" style="text-align:left">Condición</div>
      <div style="display:flex;gap:6px;margin-bottom:16px">
        <button class="btn btn-sm ${area.condition==='good'?'btn-success':'btn-outline'}" onclick="setCondition(${S.seqIdx},'good')">✓ Bien</button>
        <button class="btn btn-sm ${area.condition==='attention'?'btn-primary':'btn-outline'}" style="${area.condition==='attention'?'background:var(--warn)':''}" onclick="setCondition(${S.seqIdx},'attention')">⚠ Atención</button>
        <button class="btn btn-sm ${area.condition==='urgent'?'btn-danger':'btn-outline'}" onclick="setCondition(${S.seqIdx},'urgent')">🔴 Urgente</button>
      </div>
      <div class="field"><label>Notas</label><textarea rows="2" placeholder="Observaciones..."></textarea></div>
      <div style="display:flex;gap:8px">
        ${S.seqIdx>0?'<button class="btn btn-outline" style="flex:1" onclick="seqPrev()">← Anterior</button>':''}
        <button class="btn btn-primary" style="flex:1" onclick="seqNext()">${S.seqIdx===S.inspAreas.length-1?'✓ Finalizar':'Siguiente →'}</button>
      </div>
    </div>`;
}

