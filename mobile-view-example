// ===================== ACTIONS =====================
function switchRole(r){S.role=r;S.tab='home';S.seqMode=null;S.sheet=null;render()}
function go(t){S.tab=t;S.seqMode=null;S.sheet=null;render()}
function openSheet(s){S.sheet=s;render()}
function closeSheet(){S.sheet=null;render()}
function toggleOffline(){S.offline=!S.offline;render()}
function toggleModule(k){S.modules[k]=!S.modules[k];render()}
function startSeq(mode){S.seqMode=mode;S.seqIdx=0;render()}
function exitSeq(){S.seqMode=null;render()}
function seqNext(){
  const max=S.seqMode==='inv-count'?S.invItems.length:S.inspAreas.length;
  if(S.seqIdx<max-1){S.seqIdx++;render()}
  else exitSeq();
}
function seqPrev(){if(S.seqIdx>0){S.seqIdx--;render()}}
function adjQty(d){S.invItems[S.seqIdx].qty=Math.max(0,S.invItems[S.seqIdx].qty+d);render()}
function setCondition(i,c){S.inspAreas[i].condition=c;render()}
function checkIn(id){const v=S.vendors.find(x=>x.id===id);if(v)v.status='checked-in';render()}
function approveReport(id){const r=S.weeklyReports.find(x=>x.id===id);if(r){r.status='approved';r.complete=7}render()}

// Init
render();
</script>
