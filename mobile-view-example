    {key:'projects',icon:'🏗️',label:'Proyectos'},
    {key:'reports',icon:'📊',label:'Reportes'}
  ],
  supervisor:[
    {key:'home',icon:'🏠',label:'Inicio'},
    {key:'oversight',icon:'👁️',label:'Control'},
    {key:'reports',icon:'📊',label:'Reportes'},
    {key:'projects',icon:'🏗️',label:'Proyectos'},
    {key:'supervision',icon:'📝',label:'Supervisión'}
  ],
  admin:[
    {key:'home',icon:'🏠',label:'Inicio'},
    {key:'buildings',icon:'🏢',label:'Edificios'},
    {key:'staff',icon:'👥',label:'Personal'},
    {key:'config',icon:'⚙️',label:'Config'},
    {key:'analytics',icon:'📈',label:'Analítica'}
  ],
  propietario:[
    {key:'home',icon:'🏠',label:'Inicio'},
    {key:'docs',icon:'📄',label:'Documentos'},
    {key:'finance',icon:'💰',label:'Finanzas'},
    {key:'issues',icon:'📩',label:'Solicitudes'},
    {key:'news',icon:'📢',label:'Avisos'}
  ]
};

function condBadge(c){
  if(c==='good') return '<span class="badge badge-success">✓ Bien</span>';
  if(c==='attention') return '<span class="badge badge-warn">⚠ Atención</span>';
  return '<span class="badge badge-danger">🔴 Urgente</span>';
}
function statusBadge(s){
  if(s==='open') return '<span class="badge badge-danger">Abierto</span>';
  if(s==='progress') return '<span class="badge badge-info">En Progreso</span>';
  if(s==='resolved') return '<span class="badge badge-success">Resuelto</span>';
  if(s==='draft') return '<span class="badge badge-warn">Borrador</span>';
  if(s==='approved') return '<span class="badge badge-success">Aprobado</span>';
  if(s==='checked-in') return '<span class="badge badge-success">✓ Check-in</span>';
  if(s==='no-show') return '<span class="badge badge-danger">No Show</span>';
  return '<span class="badge badge-info">Pendiente</span>';
}
function pctBar(pct,color){
  return `<div style="height:6px;background:var(--surface);border-radius:3px;margin-top:6px"><div style="height:100%;width:${pct}%;background:var(--${color});border-radius:3px"></div></div>`;
}

function render(){
  const nav=NAV[S.role]||NAV.asistente;
  if(!nav.find(n=>n.key===S.tab)) S.tab='home';
  
  let html='';
  // Offline banner
  if(S.offline) html+='<div class="offline-banner">📡 Sin conexión — cambios guardados localmente</div>';
  // Role bar
  html+='<div class="role-bar">';
  ROLES.forEach(r=>{html+=`<button class="${S.role===r.key?'active':''}" onclick="switchRole('${r.key}')">${r.icon} ${r.label}</button>`});
  html+='</div>';
  // Topbar
  html+=`<div class="topbar"><div><h1>${S.building}</h1><div class="sub">${ROLES.find(r=>r.key===S.role).icon} ${ROLES.find(r=>r.key===S.role).label} · Hoy: 14 Abr 2026</div></div><button onclick="toggleOffline()" style="font-size:20px">${S.offline?'📡':'🔔'}</button></div>`;
  // Content
  html+='<div class="content" id="content">';
  html+=renderPage();
  html+='</div>';
  // Bottom Nav
  html+='<div class="bottomnav">';
  nav.forEach(n=>{html+=`<button class="${S.tab===n.key?'active':''}" onclick="go('${n.key}')"><span class="ico">${n.icon}</span>${n.label}</button>`});
  html+='</div>';
  // Sheet
  if(S.sheet) html+=renderSheet();
  
  document.getElementById('app').innerHTML=html;
}

function renderPage(){
  const k=S.role+'_'+S.tab;
  // Sequential modes override
  if(S.seqMode==='inv-count') return renderSeqInvCount();
  if(S.seqMode==='walkthrough') return renderSeqWalkthrough();
  
  switch(k){
    // ---- CONSERJE ----
    case 'conserje_home': return conserjeHome();
    case 'conserje_inventory': return inventoryPage();
    case 'conserje_incidents': return incidentPage();
    case 'conserje_inspections': return inspectionsPage();
    case 'conserje_vendors': return vendorPage();
    // ---- ASISTENTE ----
    case 'asistente_home': return asistenteHome();
    case 'asistente_ops': return opsPage();
    case 'asistente_vendors': return vendorPage();
    case 'asistente_projects': return projectsPage();
    case 'asistente_reports': return reportsPage();
    // ---- SUPERVISOR ----
    case 'supervisor_home': return supervisorHome();
    case 'supervisor_oversight': return oversightPage();
    case 'supervisor_reports': return reportsPage();
    case 'supervisor_projects': return projectsPage();
    case 'supervisor_supervision': return supervisionPage();
    // ---- ADMIN ----
    case 'admin_home': return adminHome();
    case 'admin_buildings': return buildingsPage();
    case 'admin_staff': return staffPage();
    case 'admin_config': return configPage();
    case 'admin_analytics': return analyticsPage();
    // ---- RESIDENTE ----
    case 'propietario_home': return residentHome();
    case 'propietario_docs': return residentDocs();
    case 'propietario_finance': return residentFinance();
    case 'propietario_issues': return residentIssues();
    case 'propietario_news': return residentNews();
    default: return '<p>Página no encontrada</p>';
  }
}

// ===================== CONSERJE =====================
function conserjeHome(){
  const lowStock=S.invItems.filter(i=>i.qty<=i.min).length;
  const openInc=S.incidents.filter(i=>i.status==='open').length;
  return `
    <h2 style="font-size:20px;margin-bottom:4px">Buenos días 👋</h2>
    <p style="color:var(--text2);margin-bottom:16px">Turno: 06:00–14:00 · Torre A</p>
    <div class="card-row">
      <div class="card"><div class="stat-val" style="color:var(--warn)">${lowStock}</div><div class="stat-label">Stock Bajo</div></div>
      <div class="card"><div class="stat-val" style="color:var(--danger)">${openInc}</div><div class="stat-label">Incidentes</div></div>
      <div class="card"><div class="stat-val" style="color:var(--accent)">3</div><div class="stat-label">Recorridos</div></div>
    </div>
    <div class="section-title">Acciones Rápidas</div>
    <div class="list-item" onclick="go('incidents');openSheet('new-incident')"><div class="ico">🚨</div><div class="info"><h4>Reportar Incidente</h4><p>Registrar nuevo evento</p></div><div class="trail">→</div></div>
    <div class="list-item" onclick="go('inventory')"><div class="ico">📦</div><div class="info"><h4>Inventario & Combustible</h4><p>Insumos, conteos y niveles</p></div><div class="trail">→</div></div>
    <div class="list-item" onclick="startSeq('walkthrough')"><div class="ico">🔍</div><div class="info"><h4>Iniciar Recorrido</h4><p>Inspección de áreas comunes</p></div><div class="trail">→</div></div>
    <div class="list-item" onclick="go('vendors')"><div class="ico">🚚</div><div class="info"><h4>Proveedores Hoy</h4><p>Check-in/out y no-shows</p></div><div class="trail">→</div></div>
    <button class="btn btn-primary btn-block mt-8" onclick="openSheet('daily-report')">📝 Entregar Reporte de Turno</button>`;
}

// ===================== ASISTENTE =====================
function asistenteHome(){
  const lowStock=S.invItems.filter(i=>i.qty<=i.min).length;
  const pendVendors=S.vendors.filter(v=>v.status==='pending').length;
  const noShows=S.vendors.filter(v=>v.status==='no-show').length;
  const draftRpt=S.weeklyReports.filter(r=>r.status==='draft').length;
  return `
    <h2 style="font-size:20px;margin-bottom:4px">Admin de Planta</h2>
    <p style="color:var(--text2);margin-bottom:16px">Villa Valencia · Semana 15 · Operaciones en sitio</p>
    <div class="card-row">
      <div class="card"><div class="stat-val" style="color:var(--warn)">${lowStock}</div><div class="stat-label">Alertas Inv.</div></div>
      <div class="card"><div class="stat-val" style="color:var(--accent)">${pendVendors}</div><div class="stat-label">Proveedores Hoy</div></div>
      <div class="card"><div class="stat-val" style="color:var(--danger)">${noShows}</div><div class="stat-label">No-Shows</div></div>
    </div>
