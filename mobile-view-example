const ROLES=[
  {key:'conserje',label:'Conserje',icon:'🛡️'},
  {key:'asistente',label:'Admin Planta',icon:'📋'},
  {key:'supervisor',label:'Supervisor',icon:'👁️'},
  {key:'admin',label:'Gerencia',icon:'🏛️'},
  {key:'propietario',label:'Residente',icon:'🏠'}
];

const STAGES=['Ideación','Evaluación','Aprobación','Ejecución','Monitoreo','Cierre'];

const NAV={
  conserje:[
    {key:'home',icon:'🏠',label:'Inicio'},
    {key:'inventory',icon:'📦',label:'Inventario'},
    {key:'incidents',icon:'🚨',label:'Incidentes'},
    {key:'inspections',icon:'🔍',label:'Recorrido'},
    {key:'vendors',icon:'🚚',label:'Proveedores'}
  ],
  asistente:[
    {key:'home',icon:'🏠',label:'Inicio'},
